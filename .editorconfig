# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Default configuration for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# Makefiles require tabs
[Makefile]
indent_style = tab

# Batch files use CRLF
[*.{bat,cmd}]
end_of_line = crlf

# Shell scripts
[*.sh]
indent_size = 2
shell = bash

# Markdown files
[*.{md,markdown,mdown,mkd}]
trim_trailing_whitespace = false  # Allow trailing spaces in markdown for line breaks
max_line_length = off

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# XML files
[*.{xml,xsd,xsl,xslt}]
indent_size = 2

# Configuration files
[*.{conf,cfg,ini}]
indent_size = 2

# Git files
[.gitignore]
indent_size = 2

# Docker files
[Dockerfile]
indent_size = 2

# HTML files
[*.{html,htm}]
indent_size = 2
max_line_length = off  # HTML can have long lines

# CSS files
[*.css]
indent_size = 2

# JavaScript/TypeScript files
[*.{js,jsx,ts,tsx}]
indent_size = 2
quote_type = single  # Prefer single quotes

# React JSX/TSX files
[*.{jsx,tsx}]
indent_size = 2

# JSON files (again, for specific rules)
[*.json]
indent_size = 2

# Python files
[*.{py,pyw}]
indent_size = 4
max_line_length = 88

# Java files
[*.java]
indent_size = 4

# C/C++ files
[*.{c,cpp,h,hpp,cc}]
indent_size = 4

# Go files
[*.go]
indent_size = tab
tab_width = 8

# Rust files
[*.rs]
indent_size = 4

# Ruby files
[*.rb]
indent_size = 2

# PHP files
[*.php]
indent_size = 4

# SQL files
[*.sql]
indent_size = 2
keyword_case = upper  # SQL keywords in uppercase

# LICENSE file
[LICENSE*]
trim_trailing_whitespace = false
insert_final_newline = false

# README files
[README*]
trim_trailing_whitespace = false

# CHANGELOG files
[CHANGELOG*]
trim_trailing_whitespace = false

# Documentation files
[*.{txt,rst,adoc}]
trim_trailing_whitespace = false

# Image files metadata
[*.{png,jpg,jpeg,gif,bmp,ico,svg}]
# Binary files, no formatting

# Binary files (no formatting)
[*.{pdf,zip,rar,7z,tar,gz,exe,dll,so,dylib}]
# Binary files, no formatting

# Log files
[*.log]
trim_trailing_whitespace = false
insert_final_newline = false

# Temporary files
[*.{tmp,temp}]
# No specific formatting

# Environment files
[*.env*]
indent_size = 2

# GitHub workflow files
[.github/workflows/*.yml]
indent_size = 2

# Docker Compose files
[docker-compose*.yml]
indent_size = 2

# VS Code settings
[.vscode/*.json]
indent_size = 2

# ESLint/Prettier configs
[.{eslint,prettier}rc*]
indent_size = 2

# Babel config
[babel.config.js]
indent_size = 2

# Webpack config
[webpack.config.js]
indent_size = 2

# Package files
[package.json]
indent_size = 2

# Lock files
[package-lock.json]
indent_size = 2
max_line_length = off  # Lock files can have very long lines

# Yarn lock file
[yarn.lock]
indent_size = 2
max_line_length = off

# Git attributes
[.gitattributes]
indent_size = 2

# EditorConfig for EditorConfig files
[.editorconfig]
indent_size = 2

# Git commit message template
[.gitmessage]
trim_trailing_whitespace = false

# Shell scripts with shebang
[**/.bash*]
indent_size = 2

# PowerShell scripts
[*.ps1]
indent_size = 2
end_of_line = crlf

# Batch files
[*.{bat,cmd}]
indent_size = 2
end_of_line = crlf

# Visual Studio project files
[*.{csproj,vbproj,vcxproj}]
indent_size = 2

# Unity files
[*.unity]
indent_size = 2

# Godot files
[*.gd]
indent_size = 4

# Lua files
[*.lua]
indent_size = 2

# Perl files
[*.pl]
indent_size = 4

# Scala files
[*.scala]
indent_size = 2

# Kotlin files
[*.kt]
indent_size = 4

# Swift files
[*.swift]
indent_size = 4

# Dart files
[*.dart]
indent_size = 2

# Elm files
[*.elm]
indent_size = 4

# Haskell files
[*.hs]
indent_size = 2

# Clojure files
[*.clj]
indent_size = 2

# F# files
[*.fs]
indent_size = 4

# Julia files
[*.jl]
indent_size = 4

# R files
[*.r]
indent_size = 2

# MATLAB files
[*.m]
indent_size = 4

# LaTeX files
[*.{tex,sty,cls}]
indent_size = 2

# BibTeX files
[*.bib]
indent_size = 2

# AsciiDoc files
[*.adoc]
indent_size = 2

# reStructuredText files
[*.rst]
indent_size = 2

# Textile files
[*.textile]
indent_size = 2

# Haml files
[*.haml]
indent_size = 2

# Slim files
[*.slim]
indent_size = 2

# Pug/Jade files
[*.{pug,jade}]
indent_size = 2

# Stylus files
[*.styl]
indent_size = 2

# Sass/SCSS files
[*.{sass,scss}]
indent_size = 2

# Less files
[*.less]
indent_size = 2

# Stylus files
[*.styl]
indent_size = 2

# GraphQL files
[*.{graphql,gql}]
indent_size = 2

# Protobuf files
[*.proto]
indent_size = 2

# Thrift files
[*.thrift]
indent_size = 2

# OpenAPI/Swagger files
[*.{yaml,yml}:schema(openapi)]
indent_size = 2

# CSV/TSV files
[*.{csv,tsv}]
# No formatting for data files

# Excel files (XML-based)
[*.xlsx]
# Binary files, no formatting

