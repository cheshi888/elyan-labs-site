# Elyan Labs Site specific exclusions
# Exclude development configuration files
config.local.json
.env.development

# Exclude large media assets not needed in container
assets/raw/
assets/unoptimized/

# Exclude documentation files if not needed
docs/source/
docs/build/

# Exclude development tools
dev-tools/
scripts/dev/

# Exclude test data
test-data/
fixtures/
mocks/

# Exclude CI/CD configuration if not needed for runtime
.github/workflows/
.gitlab-ci.yml
.circleci/
.travis.yml

# Exclude local database files
*.db
*.sqlite
*.sqlite3

# Exclude temporary uploads
uploads/temp/
tmp_uploads/

