# ESLint Ignore Patterns
# Files and directories that ESLint should ignore

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/
.temp/
.tmp/
.ssr/
.client/
.server/

# Coverage reports
coverage/
.nyc_output/

# Dependencies
node_modules/
jspm_packages/
web_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# TypeScript build info
*.tsbuildinfo

# Framework-specific
.next/
.nuxt/
.cache/
public/

# Package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Parcel Bundler
.parcel-cache/

# Next.js Build Output
.next

# Nuxt.js Build / Telemetry
.nuxt
.output

# Storybook
storybook-static/

# Chrome User Data
chrome-user-data/

# Production
.cache/
.next/
.nuxt/
dist/
build/

# Misc
.sass-cache/
*.css.map
*.js.map
*.sourcemap
.connect.lock
.lock-wscript
.wafpickle-*

# Temp Files
*.tmp
*.temp
.tmp/
temp/

# Backup Files
*.bak
*.backup
*.old

# Secret Files
secrets*.yml
secrets*.yaml
secrets*.json
*.pem
*.key
*.crt
*.cer

# Docker
docker-compose.override.yml
.dockerignore

# Kubernetes
kubeconfig
*.kubeconfig

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
.terraform.tfstate.lock.info

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.hypothesis/
.pytest_cache/
cover/
*.mo
*.pot
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# Jupyter Notebook
.ipynb_checkpoints

