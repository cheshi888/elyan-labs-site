{
  "$schema": "https://json.schemastore.org/prettierrc",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "avoid",
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",
  "endOfLine": "lf",
  "embeddedLanguageFormatting": "auto",
  "singleAttributePerLine": false,
  
  "overrides": [
    {
      "files": ["*.json", "*.json5", "*.jsonc"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["*.md", "*.markdown", "*.mdown", "*.mkd"],
      "options": {
        "tabWidth": 2,
        "printWidth": 80,
        "proseWrap": "always"
      }
    },
    {
      "files": ["*.html", "*.htm"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120,
        "htmlWhitespaceSensitivity": "ignore"
      }
    },
    {
      "files": ["*.css", "*.scss", "*.less"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["*.js", "*.jsx", "*.ts", "*.tsx"],
      "options": {
        "tabWidth": 2,
        "printWidth": 100
      }
    },
    {
      "files": ["*.py", "*.pyw"],
      "options": {
        "tabWidth": 4,
        "printWidth": 88
      }
    },
    {
      "files": ["*.java"],
      "options": {
        "tabWidth": 4,
        "printWidth": 120
      }
    },
    {
      "files": ["*.c", "*.cpp", "*.h", "*.hpp", "*.cc"],
      "options": {
        "tabWidth": 4,
        "printWidth": 120
      }
    },
    {
      "files": ["*.go"],
      "options": {
        "tabWidth": 8,
        "useTabs": true,
        "printWidth": 120
      }
    },
    {
      "files": ["*.rs"],
      "options": {
        "tabWidth": 4,
        "printWidth": 100
      }
    },
    {
      "files": ["*.rb"],
      "options": {
        "tabWidth": 2,
        "printWidth": 100
      }
    },
    {
      "files": ["*.php"],
      "options": {
        "tabWidth": 4,
        "printWidth": 120
      }
    },
    {
      "files": ["*.sol"],
      "options": {
        "tabWidth": 4,
        "printWidth": 120
      }
    },
    {
      "files": ["*.vy"],
      "options": {
        "tabWidth": 4,
        "printWidth": 120
      }
    },
    {
      "files": ["*.sql"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["Dockerfile", "*.dockerfile"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["Makefile", "*.mk"],
      "options": {
        "tabWidth": 8,
        "useTabs": true
      }
    },
    {
      "files": ["*.sh", "*.bash"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["*.xml", "*.xsd", "*.xsl", "*.xslt"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["*.graphql", "*.gql"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["*.proto"],
      "options": {
        "tabWidth": 2,
        "printWidth": 120
      }
    },
    {
      "files": ["*.vue"],
      "options": {
        "tabWidth": 2,
        "printWidth": 100
      }
    },
    {
      "files": ["*.svelte"],
      "options": {
        "tabWidth": 2,
        "printWidth": 100
      }
    },
    {
      "files": ["*.astro"],
      "options": {
        "tabWidth": 2,
        "printWidth": 100
      }
    }
  ],
  
  "plugins": [],
  
  "bounty": {
    "task": "Add a .prettierrc file to any repo missing one (Issue #1627)",
    "paymentAddress": {
      "erc20": "0xB3ff5422f49324FD99a0AB7905440C9586d99999",
      "trc20": "TGPZ5ozM1LLxXyErA45hKfcuR2cF7ntcsk"
    },
    "submittedBy": "cheshi888",
    "timestamp": "2024-03-12T05:10:00Z"
  }
}